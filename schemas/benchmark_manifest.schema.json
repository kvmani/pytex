{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "pytex.benchmark_manifest",
  "title": "PyTex Benchmark Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_id",
    "schema_version",
    "pytex_version",
    "created_at",
    "benchmark_id",
    "subsystem",
    "baseline_kind",
    "workflows",
    "fixture_ids",
    "artifact_paths",
    "tolerances",
    "status",
    "notes"
  ],
  "properties": {
    "schema_id": { "const": "pytex.benchmark_manifest" },
    "schema_version": { "const": "1.0.0" },
    "pytex_version": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "minLength": 1 },
    "benchmark_id": { "type": "string", "minLength": 1 },
    "subsystem": { "type": "string", "minLength": 1 },
    "baseline_kind": { "type": "string", "minLength": 1 },
    "workflows": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "fixture_ids": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "artifact_paths": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "tolerances": {
      "type": "object",
      "additionalProperties": { "type": "number", "minimum": 0.0 }
    },
    "status": { "type": "string", "minLength": 1 },
    "notes": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    }
  }
}
